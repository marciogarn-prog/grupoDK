{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "node scripts/copy-portal-for-vercel.cjs",
  "outputDirectory": ".vercel-portal-dist",
  "installCommand": "npm install",
  "cleanUrls": true,
  "trailingSlash": false,
  "env": {
    "CRON_SECRET": "1234",
    "DK_BACKUP_EMAIL_TO": "marciogarn@gmail.com",
    "DK_BACKUP_EMAIL_FROM": "Grupo DK Backup <marciogarn@gmail.com>",
    "SUPABASE_URL": "https://ppxtwqvzgujllfzarpuz.supabase.co",
    "SUPABASE_ANON_KEY": "sb_publishable_Nm-Et1yeL66vgoA2rqD__w_CLtGauk3",
    "SMTP_USER": "marciogarn@gmail.com",
    "SMTP_PASS": "1234",
    "SMTP_HOST": "smtp.gmail.com",
    "SMTP_PORT": "465"
  },
  "crons": [
    {
      "path": "/api/cron-daily-backup",
      "schedule": "0 5 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [{ "key": "X-Content-Type-Options", "value": "nosniff" }]
    },
    {
      "source": "/:path*.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
