{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "node scripts/copy-portal-for-vercel.cjs",
  "outputDirectory": ".vercel-portal-dist",
  "installCommand": "npm install",
  "cleanUrls": true,
  "trailingSlash": false,
  "env": {
    "CRON_SECRET": "1234",
    "DK_BACKUP_EMAIL_TO": "marciogarn@gmail.com"
  },
  "crons": [
    {
      "path": "/api/cron-daily-backup",
      "schedule": "0 5 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [{ "key": "X-Content-Type-Options", "value": "nosniff" }]
    },
    {
      "source": "/:path*.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
